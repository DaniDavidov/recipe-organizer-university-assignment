<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= author %></title>
    <style>
      body { font-family: Arial, sans-serif; max-width: 900px; margin: 40px auto; padding: 0 16px; }
      h1 { color: #1D9E75; }
      a { color: #1D9E75; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .back { margin-bottom: 24px; display: block; }
      .recipe { border: 1px solid #ddd; border-radius: 8px; padding: 16px; margin-bottom: 16px; }
      .recipe h3 { margin: 0 0 8px 0; }
      .tag { display: inline-block; background: #E1F5EE; color: #0F6E56; padding: 2px 10px; border-radius: 20px; font-size: 12px; margin-right: 4px; }
      .meta { color: #888; font-size: 13px; margin-bottom: 8px; }
      .rating { color: #EF9F27; font-weight: bold; }
    </style>
  </head>
  <body>
    <a class="back" href="/">← Back to all recipes</a>

    <h1><%= author %></h1>

    <% if (stats) { %>
      <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:24px;">
        <div style="background:#F8FFFE; border:1px solid #9FE1CB; border-radius:8px; padding:14px 20px; text-align:center; min-width:100px;">
          <div style="font-size:24px; font-weight:bold; color:#1D9E75;"><%= stats.total_recipes %></div>
          <div style="font-size:12px; color:#888; margin-top:2px;">Recipes</div>
        </div>
        <div style="background:#F8FFFE; border:1px solid #9FE1CB; border-radius:8px; padding:14px 20px; text-align:center; min-width:100px;">
          <div style="font-size:24px; font-weight:bold; color:#EF9F27;">★ <%= stats.avg_rating.toFixed(1) %></div>
          <div style="font-size:12px; color:#888; margin-top:2px;">Avg Rating</div>
        </div>
        <div style="background:#F8FFFE; border:1px solid #9FE1CB; border-radius:8px; padding:14px 20px; min-width:160px;">
          <div style="font-size:12px; color:#888; margin-bottom:6px;">Categories</div>
          <div>
            <% stats.categories.forEach(cat => { %>
              <span style="display:inline-block; background:#E1F5EE; color:#0F6E56; padding:2px 10px; border-radius:20px; font-size:12px; margin-right:4px;"><%= cat %></span>
            <% }) %>
          </div>
        </div>
      </div>
    <% } %>
    <p><strong><%= recipes.length %></strong> recipe(s) by this author</p>

    <% if (recipes.length === 0) { %>
      <p>No recipes found for this author.</p>
    <% } %>

    <% recipes.forEach((recipe) => { %>
      <div class="recipe">
        <h3><a href="/recipes/<%= recipe._id %>"><%= recipe.title %></a></h3>
        <div class="meta">
          Category: <strong><%= recipe.category %></strong> ·
          Difficulty: <strong><%= recipe.difficulty %></strong> ·
          <span class="rating">★ <%= recipe.rating %></span>
        </div>
        <div>
          <% (recipe.tags || []).forEach((tag) => { %>
            <span class="tag"><%= tag %></span>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </body>
</html>